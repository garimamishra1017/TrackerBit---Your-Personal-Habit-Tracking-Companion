# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
DEBUG=True

# Security
SECRET_KEY=your-secret-key-here  # Change this to a secure random string
JWT_SECRET_KEY=your-jwt-secret-key-here  # Change this for JWT token encryption

# Database
DATABASE_URL=sqlite:///trackerbit.db

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Admin Account (First-time setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@trackerbit.com
